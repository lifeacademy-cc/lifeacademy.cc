# ================================================================
# LIFE Academy — Environment Variables
# Copy this file to .env.local and fill in real values
# ================================================================

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── LINE Messaging API ───────────────────────────────────────
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_ADMIN_USER_ID=Ue652c6a963399b81a811eb04fe88c123

# ─── Resend Email ─────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ─── Anthropic (Phase 3 only) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ─── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://lifeacademy.co.th
NEXT_PUBLIC_APP_NAME=LIFE Academy
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/LifeHadyai
